# Server
PORT=5000
NODE_ENV=development

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=gymflow_saas

# JWT
JWT_SECRET=gymflow_super_secret_key_change_in_production_2024
JWT_REFRESH_SECRET=gymflow_refresh_secret_key_change_in_production_2024
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=7d

# Google OAuth (configure when ready)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email (configure SMTP for production)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@gymflow.com

# Frontend URL
CLIENT_URL=http://localhost:5173
